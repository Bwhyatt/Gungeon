    return True
def CheckConnections(GivenGrid, GivenNum, GivenRoomLen, NumberBeenChecked):
    ConnectionNum = 0
    NumberChecked = NumberBeenChecked
    i = GivenNum[1]
    j = GivenNum[0]
    CheckedList = []
    ValidateList = []
    if(GivenGrid[i - 1][j] != '' and GivenGrid[i-1][j] not in CheckedList):
        ConnectionNum += 1
        NumberChecked += 1
        ValidateList.append((i -1,j))
    if(GivenGrid[i +1][j] != ''and GivenGrid[i+1][j] not in CheckedList):
        ConnectionNum += 1
        NumberChecked += 1
        ValidateList.append((i +1,j))
    if(GivenGrid[i][j-1] != '' and GivenGrid[i][j-1] not in CheckedList):
        ConnectionNum += 1
        NumberChecked += 1
        ValidateList.append((i, j-1))
    if(GivenGrid[i][j+1] != '' and GivenGrid[i][j+1] not in CheckedList):
        ConnectionNum += 1
        NumberChecked += 1
        ValidateList.append((i, j+1))
    CheckedList.append(GivenGrid[i][j])
    if(NumberBeenChecked < GivenRoomLen):
        for n in range(len(ValidateList)):
            return ConnectionNum + CheckConnections(GivenGrid,ValidateList[n] ,GivenRoomLen, NumberChecked)
                #print(len(GivenGrid[0]) * len(GivenGrid) - counter)
    else:
        return ConnectionNum
